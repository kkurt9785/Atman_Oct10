# Supabase (server only)
SUPABASE_URL=https://xxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Supabase browser / user-scoped server client
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-or-publishable-key

# Admin facility context cookie: random 32+ chars, production secret manager only
FACILITY_COOKIE_SECRET=replace-with-at-least-32-random-characters

# Kakao OAuth
NEXT_PUBLIC_KAKAO_REST_API_KEY=replace-me
NEXT_PUBLIC_KAKAO_JS_KEY=replace-me

# Toss Payments (use test keys outside production)
BILLING_MODEL=saas_direct_wage
ENABLE_LEGACY_WAGE_CREDIT=false
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_replace-me
TOSS_SECRET_KEY=test_sk_replace-me
# Toss webhook URL may use ?token=<this-value>; random 24+ chars
TOSS_WEBHOOK_TOKEN=replace-with-random-webhook-token

# Vercel cron / durable push outbox
CRON_SECRET=replace-with-random-cron-token
VAPID_SUBJECT=mailto:security@example.com
VAPID_PUBLIC_KEY=replace-me
VAPID_PRIVATE_KEY=replace-me

# Demo controls: must be 0/unset in production
NEXT_PUBLIC_ENABLE_DEMO_LOGIN=0
