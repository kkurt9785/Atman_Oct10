# Supabase — 서버 사이드 전용 (브라우저 노출 금지)
# Supabase 대시보드 > Settings > API에서 복사
SUPABASE_URL=https://xxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 임시 org 고정 (auth 구현 전 데모용) — facilities.id UUID
ORG_ID=00000000-0000-0000-0000-000000000000

# 브라우저 클라이언트용 공개 키
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_KAKAO_JS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 로컬/시연 환경에서만 관리자 데모 로그인 버튼 노출
NEXT_PUBLIC_ENABLE_DEMO_LOGIN=1
