# Supabase browser client
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-or-publishable-key

# Kakao OAuth (public identifier only)
NEXT_PUBLIC_KAKAO_REST_API_KEY=replace-me
KAKAO_REST_API_KEY=replace-me
KAKAO_CLIENT_SECRET=replace-me

# Web Push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace-me

# Demo login must be disabled in production
NEXT_PUBLIC_ENABLE_DEMO_LOGIN=0

# Product money flow (server environment should use the same values)
BILLING_MODEL=saas_direct_wage
ENABLE_LEGACY_WAGE_CREDIT=false
